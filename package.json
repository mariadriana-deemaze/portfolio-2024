{
	"name": "portfolio-2025",
	"private": true,
	"version": "0.0.0",
	"license": "UNLICENSED",
	"type": "module",
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"commit": "git-cz",
		"dev": "vite dev",
		"build": "vite build",
		"typecheck": "tsc --noEmit",
		"start": "node .output/server/index.mjs",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format --check .",
		"validate": "tsc --noEmit && biome check . && knip",
		"preview": "vite preview",
		"cms": "pnpm --dir cms dev",
		"dev:cms": "pnpm --dir cms dev",
		"validate:all": "pnpm validate && pnpm --dir cms validate",
		"build:all": "pnpm build && pnpm --dir cms build"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@portabletext/markdown": "^1.4.1",
		"@portabletext/react": "^6.2.0",
		"@radix-ui/react-avatar": "^1.0.4",
		"@radix-ui/react-dialog": "^1.0.5",
		"@radix-ui/react-dropdown-menu": "^2.0.5",
		"@radix-ui/react-icons": "^1.3.0",
		"@radix-ui/react-label": "^2.0.2",
		"@radix-ui/react-slot": "^1.0.2",
		"@tanstack/react-query": "^5.90.6",
		"@tanstack/react-router": "^1.163.2",
		"@tanstack/react-start": "^1.163.2",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.0.0",
		"cmdk": "^1.0.0",
		"date-fns": "^4.0.0",
		"lenis": "^1.2.3",
		"nodemailer": "^9.0.1",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-hook-form": "^7.52.2",
		"react-icons": "^5.3.0",
		"shiki": "4.0.2",
		"sonner": "^2.0.0",
		"tailwind-merge": "^3.0.0",
		"tailwindcss-animate": "^1.0.6",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/postcss": "^4.1.16",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^24.10.1",
		"@types/react": "^19.0.10",
		"@types/react-dom": "^19.0.4",
		"@vitejs/plugin-react": "^6.0.0",
		"commitizen": "^4.3.1",
		"cz-customizable": "^7.5.1",
		"knip": "^6.0.0",
		"nitro": "npm:nitro-nightly@latest",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.0.17",
		"typescript": "^6.0.0",
		"vite": "^8.0.0"
	},
	"config": {
		"commitizen": {
			"path": "cz-customizable"
		},
		"cz-customizable": {
			"config": ".cz-config.cjs"
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		],
		"overrides": {
			"@tanstack/start-plugin-core>srvx": "0.11.16",
			"@tanstack/start-server-core>h3-v2": "npm:h3@2.0.1-rc.22",
			"ajv>fast-uri": "3.1.2",
			"anymatch>picomatch": "4.0.4",
			"commitizen>lodash": "4.18.1",
			"cz-customizable>lodash": "4.18.1",
			"dompurify": "3.4.11",
			"filelist>minimatch": "10.2.5",
			"micromatch>picomatch": "4.0.4",
			"readdirp>picomatch": "4.0.4",
			"tmp": "^0.2.4",
			"@actions/github>undici": "8.5.0",
			"@actions/http-client>undici": "8.5.0",
			"@vercel/frameworks>js-yaml": "4.2.0",
			"typeid-js>uuid": "11.1.1",
			"@sanity/uuid>uuid": "11.1.1",
			"esbuild": "0.28.1"
		}
	}
}
